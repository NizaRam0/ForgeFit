{
    "name": "forgefit/api",
    "type": "project",
    "require": {
        "php": "^8.2.0",
        "laravel/framework": "^11.0",
        "openai-php/client": "^0.19.2",
        "laravel/sanctum": "^4.3.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeders",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
